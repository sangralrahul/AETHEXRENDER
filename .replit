modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ZOHO_USER = "email@aethex.in"
ZOHO_HOST = "smtp.zoho.in"
ZOHO_PORT = "465"
ZOHO_FROM_NAME = "AETHEX Medical"
ADMIN_EMAIL = "email@aethex.in"
SITE_URL = "https://aethex.in"
FROM_EMAIL = "email@aethex.in"
